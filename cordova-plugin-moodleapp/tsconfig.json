{
    "compilerOptions": {
        "target": "esnext",
        "module": "node16",
        "moduleResolution": "nodenext",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "experimentalDecorators": true,
    },
    "include": [
        "src/ts/**/*.ts",
        "types/**.d.ts"
    ]
}
