engine-strict=true

# Avoid installing/updating packages released less than 3 days ago.
# To bypass in a specific install: npm install --min-release-age=0
# Requires npm 11+ (bundled with Node 24).
min-release-age=3

# Disallow fetching dependencies directly from git URLs.
# If a custom app needs a git-sourced package, override with --allow-git=all.
# Requires npm 11+ (bundled with Node 24).
allow-git=root
